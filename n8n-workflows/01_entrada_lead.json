        1340,
        400
      ]
    },
    {
      "parameters": {
        "jsCode": "const montar   = $('Montar Payloads').item.json;\nconst rdResp   = $('Criar Deal RD Station').item.json;\nconst dealId   = rdResp?._id || rdResp?.id || null;\n\nconst payload  = JSON.parse(montar.supabase_payload);\npayload.crm_deal_id = dealId;\n\nreturn [{ json: { payload: JSON.stringify(payload) } }];"
      },
