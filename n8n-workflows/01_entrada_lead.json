      "id": "n-get-client",
      "name": "Buscar Nome Cliente",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        900,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "const lead    = $('Preparar Dados').item.json;\nconst configs = $('Buscar Config CRM').item.json;\nconst clients = $('Buscar Nome Cliente').item.json;\n\nconst config   = Array.isArray(configs) ? configs[0] : configs;\nconst clientRec = Array.isArray(clients) ? clients[0] : clients;\n\nif (!config) throw new Error('Configuração CRM não encontrada para este cliente');\n\nconst mapeamento  = config.crm_mapeamento || {};\nconst nomeFantasia = (clientRec?.nome_fantasia || '').toLowerCase().replace(/\\s+/g, '-').replace(/[^a-z0-9-]/g, '');\n\nconst msg1 = `${lead.saudacao} ${lead.primeiro_nome}, tudo bem?`;\n\nconst historico_conversa = [{ role: 'assistant', content: msg1, ts: new Date().toISOString() }];\nconst proxima_acao_at = new Date(Date.now() + 5 * 60 * 1000).toISOString();\n\nreturn [{\n  json: {\n    lead,\n    config,\n    mapeamento,\n    instance_name: nomeFantasia,\n    msg1,\n    rd_payload: JSON.stringify({\n      deal: {\n        name: lead.nome,\n        deal_pipeline_id: config.crm_pipeline_id,\n        deal_stage_id: mapeamento.tentativa_1\n      }\n    }),\n    supabase_payload: JSON.stringify({\n      client_id:       lead.client_id,\n      nome:            lead.nome,\n      telefone:        lead.telefone,\n      email:           lead.email,\n      origem:          lead.origem,\n      estado:          'tentativa_1',\n      proxima_acao:    'follow_up_5min',\n      proxima_acao_at,\n      historico_conversa\n    })\n  }\n}];"
      },
